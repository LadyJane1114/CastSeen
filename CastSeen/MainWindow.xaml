<Window x:Class="CastSeen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CastSeen"
        xmlns:views="clr-namespace:CastSeen.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    
    <Grid Background="{StaticResource col_background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <views:MenuView DataContext="{Binding}"/>
        </Border>
        <Border Grid.Column="1" ClipToBounds="True">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
