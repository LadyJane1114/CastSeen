<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!--Pallette and Fonts-->
    <SolidColorBrush x:Key="col_background" Color="#1C1C22"/>
    <SolidColorBrush x:Key="col_foreground" Color="#F1EDE4"/>
    <SolidColorBrush x:Key="col_card" Color="#23232A"/>
    
    <SolidColorBrush x:Key="col_primary" Color="#6E1E2E"/>
    <SolidColorBrush x:Key="col_secondary" Color="#333338"/>
    <SolidColorBrush x:Key="col_muted" Color="#2D2D31"/>
    <SolidColorBrush x:Key="col_muted_foreground" Color="#8C8C91"/>

    <SolidColorBrush x:Key="col_accent" Color="#BFBFBF"/>
    <SolidColorBrush x:Key="col_destructive" Color="#EF4446"/>
    <SolidColorBrush x:Key="col_destructive_foreground" Color="#F8FAFC"/>

    <SolidColorBrush x:Key="col_borders" Color="#38383D"/>

    <SolidColorBrush x:Key="col_burgundy_glow" Color="#A63D52"/>
    <SolidColorBrush x:Key="col_burgundy_light" Color="#8A3A4A"/>

    <FontFamily x:Key="font_headers">Broadway</FontFamily>
    <FontFamily x:Key="font_text">Verdana</FontFamily>


    <!--Buttons-->
    
    
    
</ResourceDictionary>