<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!--Pallette and Fonts-->
    <SolidColorBrush x:Key="col_background" Color="#1C1C22"/>
    <SolidColorBrush x:Key="col_foreground" Color="#F1EDE4"/>
    <SolidColorBrush x:Key="col_card" Color="#23232A"/>
    
    <SolidColorBrush x:Key="col_primary" Color="#6E1E2E"/>
    <SolidColorBrush x:Key="col_secondary" Color="#333338"/>
    <SolidColorBrush x:Key="col_muted" Color="#2D2D31"/>
    <SolidColorBrush x:Key="col_muted_foreground" Color="#8C8C91"/>

    <SolidColorBrush x:Key="col_accent" Color="#BFBFBF"/>
    <SolidColorBrush x:Key="col_destructive" Color="#EF4446"/>
    <SolidColorBrush x:Key="col_destructive_foreground" Color="#F8FAFC"/>

    <SolidColorBrush x:Key="col_borders" Color="#38383D"/>

    <SolidColorBrush x:Key="col_burgundy_glow" Color="#A63D52"/>
    <SolidColorBrush x:Key="col_burgundy_light" Color="#8A3A4A"/>

    <FontFamily x:Key="font_headers">Broadway</FontFamily>
    <FontFamily x:Key="font_text">Verdana</FontFamily>



    <!-- Sidebar menu item style -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_primary}" />
                            <Setter Property="Foreground" Value="{StaticResource col_destructive_foreground}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_primary}" />
                            <Setter Property="Foreground" Value="{StaticResource col_destructive_foreground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource col_muted_foreground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox styles for movie filters -->
    <Style x:Key="MovieComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_primary}" />
                            <Setter Property="Foreground" Value="{StaticResource col_destructive_foreground}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_primary}" />
                            <Setter Property="Foreground" Value="{StaticResource col_destructive_foreground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MovieComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource col_burgundy_light}" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="BorderBrush" Value="{StaticResource col_borders}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinWidth" Value="140" />
        <Setter Property="MaxDropDownHeight" Value="220" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Grid.Column="0"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="{StaticResource col_burgundy_light}"
                                      BorderThickness="0"
                                      Focusable="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="4,0,4,0" VerticalAlignment="Center" HorizontalAlignment="Left" RecognizesAccessKey="True"/>
                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0 Z" Fill="{TemplateBinding Foreground}" Width="8" Height="6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </ToggleButton>

                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{StaticResource col_burgundy_light}"
                                    BorderBrush="{StaticResource col_borders}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="4"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#A63D52" BlurRadius="12" ShadowDepth="0" Opacity="0.45" />
                                </Border.Effect>
                                <ScrollViewer CanContentScroll="True" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="PART_Popup" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger SourceName="ToggleButton" Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource col_primary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- Sidebar button style -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="BorderBrush" Value="{StaticResource col_borders}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_primary}" />
                            <Setter Property="Foreground" Value="{StaticResource col_destructive_foreground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_burgundy_light}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource col_muted_foreground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Home page primary button-->
    <Style x:Key="HomePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
        <Setter Property="Background" Value="{StaticResource col_primary}" />
        <Setter Property="Foreground" Value="{StaticResource col_destructive_foreground}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="140" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#A63D52" BlurRadius="12" ShadowDepth="0" Opacity="0.6" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_burgundy_light}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_burgundy_light}" />
                            <Setter TargetName="Bd" Property="Opacity" Value="0.95" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource col_muted_foreground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Home page dark button -->
    <Style x:Key="HomeDarkButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
        <Setter Property="Background" Value="{StaticResource col_secondary}" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="140" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="0" Opacity="0.25" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_muted}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_borders}" />
                            <Setter TargetName="Bd" Property="Opacity" Value="0.95" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource col_muted_foreground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--Filter buttons-->
    <Style x:Key="FilterButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
        <Setter Property="Background" Value="{StaticResource col_burgundy_light}" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="5,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="50" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                     Background="{TemplateBinding Background}"
                     CornerRadius="8"
                     Padding="{TemplateBinding Padding}"
                     SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="0" Opacity="0.25" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_muted}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource col_borders}" />
                            <Setter TargetName="Bd" Property="Opacity" Value="0.95" />
                        </Trigger>
                        
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource col_muted_foreground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TopGenresButtonStyle" TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
        <Setter Property="Background" Value="{StaticResource col_secondary}" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Width" Value="75"/>
    </Style>
    
    <!--Search Bar-->
    <Style x:Key="SearchBarStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource col_secondary}" />
        <Setter Property="Foreground" Value="{StaticResource col_foreground}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderBrush" Value="{StaticResource col_borders}" />
        <Setter Property="BorderThickness" Value="1" />

    </Style>
</ResourceDictionary>