<UserControl x:Class="CastSeen.Views.DetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CastSeen.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Button Command="{Binding BackCommand}"
                        Style="{StaticResource HomeDarkButtonStyle}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource icon_back}" Width="12" Height="12" Stretch="Uniform" Fill="{StaticResource col_foreground}" Margin="0,0,5,0"/>
                        <TextBlock Text="Back" FontSize="12" FontFamily="{StaticResource font_text}" Foreground="{StaticResource col_foreground}"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="Loading details..."
                           Visibility="{Binding LoadingVisibility}"
                           Foreground="{StaticResource col_muted_foreground}"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{Binding Header}" FontSize="16" Foreground="{StaticResource col_accent}" FontFamily="{StaticResource font_text}"/>

                <Border Height="1" Background="{StaticResource col_muted}" Margin="16,5"/>

                <StackPanel Visibility="{Binding ActorSectionVisibility}" HorizontalAlignment="Center">
                    <Grid Margin="0,10" HorizontalAlignment="Center">
                        <Ellipse Fill="{StaticResource col_primary}" Width="300" Height="50" Opacity="0.5" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-5"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <TextBlock Text="{Binding ActorName}" FontSize="34" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}" HorizontalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding ActorLifeYears}" Margin="0,4,0,0" Foreground="{StaticResource col_muted_foreground}" HorizontalAlignment="Center" FontFamily="{StaticResource font_text}"/>

                    <TextBlock Text="{Binding ActorProfessions, StringFormat=Professions: {0}}" Margin="0,4,0,0" Foreground="{StaticResource col_muted_foreground}" FontFamily="{StaticResource font_text}"/>
                    <TextBlock Text="{Binding ActorProjectCount, StringFormat=Projects: {0}}" Margin="0,4,0,14" Foreground="{StaticResource col_accent}" FontFamily="{StaticResource font_text}"/>

                    <TextBlock Text="Known For" FontSize="16" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
                    <ItemsControl ItemsSource="{Binding ActorKnownFor}" Margin="0,6,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#22FFFFFF" Padding="6,3" Margin="0,0,0,6" CornerRadius="4">
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_text}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Credits" FontSize="16" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
                    <ItemsControl ItemsSource="{Binding ActorCredits}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource col_muted_foreground}" Margin="0,0,0,6" FontFamily="{StaticResource font_text}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Visibility="{Binding MovieSectionVisibility}" HorizontalAlignment="Center">
                    <Grid>
                        <Ellipse Fill="{StaticResource col_primary}" Width="300" Height="50" Opacity="0.5" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-5"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <TextBlock Text="{Binding MovieTitle}" FontSize="34" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}" HorizontalAlignment="Center"/>
                    </Grid>
                    
                    <TextBlock Text="{Binding MovieSubtitle}" Margin="0,4,0,0" Foreground="{StaticResource col_muted_foreground}" FontSize="22" FontFamily="{StaticResource font_text}" HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding MovieRatingText, StringFormat=Rating: {0}}" Margin="0,4,0,14" Foreground="{StaticResource col_accent}" FontFamily="{StaticResource font_text}" HorizontalAlignment="Center" FontSize="16"/>

                    <TextBlock Text="Genres" FontSize="16" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
                    <ItemsControl ItemsSource="{Binding MovieGenres}" Margin="0,6,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#22FFFFFF" Padding="6,3" Margin="0,0,6,6" CornerRadius="4">
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_text}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Top Cast" FontSize="16" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
                    <ItemsControl ItemsSource="{Binding MovieTopCast}" Margin="0,6,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource col_muted_foreground}" Margin="0,0,0,6" FontFamily="{StaticResource font_text}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Directors" FontSize="16" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
                    <ItemsControl ItemsSource="{Binding MovieDirectors}" Margin="0,6,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource col_muted_foreground}" Margin="0,0,0,6" FontFamily="{StaticResource font_text}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Writers" FontSize="16" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
                    <ItemsControl ItemsSource="{Binding MovieWriters}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource col_muted_foreground}" Margin="0,0,0,6" FontFamily="{StaticResource font_text}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
