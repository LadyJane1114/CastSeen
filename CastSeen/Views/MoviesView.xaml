<UserControl x:Class="CastSeen.Views.MoviesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CastSeen.Views"
             xmlns:vm="clr-namespace:CastSeen.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:MoviesViewModel/>
    </UserControl.DataContext>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Browse Collection" Foreground="{StaticResource col_muted_foreground}" FontFamily="{StaticResource font_text}" FontSize="14"/>
            <TextBlock Text="Movies" FontSize="38" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
            <Border Height="1" Background="{StaticResource col_muted}" Margin="16,5"/>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Movies}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource col_card}" Margin="0,0,0,5" Padding="10,5" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PrimaryTitle}" FontSize="14" Foreground="{StaticResource col_foreground}" FontWeight="Bold" FontFamily="{StaticResource font_text}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding StartYear}" FontSize="14" Foreground="{StaticResource col_muted_foreground}" FontFamily="{StaticResource font_text}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Previous 50" Command="{Binding PreviousPageCommand}" Margin="0,0,10,0" Padding="10,5" Background="{StaticResource col_card}" Foreground="{StaticResource col_foreground}" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Next 50" Command="{Binding NextPageCommand}" Padding="10,5" Background="{StaticResource col_card}" Foreground="{StaticResource col_foreground}" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
