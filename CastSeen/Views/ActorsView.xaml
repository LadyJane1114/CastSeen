<UserControl x:Class="CastSeen.Views.ActorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CastSeen.Views"
             xmlns:vm="clr-namespace:CastSeen.ViewModels"
             xmlns:helper="clr-namespace:CastSeen.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Vertical">
            <TextBlock Text="Explore Profiles" Foreground="{StaticResource col_muted_foreground}" FontFamily="{StaticResource font_text}" FontSize="14"/>
            <TextBlock Text="Actors" FontSize="38" Foreground="{StaticResource col_foreground}" FontFamily="{StaticResource font_headers}"/>
            <TextBlock Text="Loading actors..."
                       Visibility="{Binding LoadingVisibility}"
                       Foreground="{StaticResource col_muted_foreground}"
                       Margin="0,6,0,0"/>
            <Border x:Name="Divider"  Height="1" Background="{StaticResource col_muted}" Margin="16,5"/>
        </StackPanel>

        <!--Search Bar-->
        <StackPanel x:Name="SearchStackPanel" Grid.Row="1" Orientation="Vertical">
            <TextBox  helper:TextBoxHelper.Placeholder="🔍 Search by actor name" Style="{StaticResource ResourceKey=SearchBarStyle}"
                      x:Name="SearchBar"  Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Height="{Binding Height, ElementName=SearchStackPanel}" Width="{Binding Width, ElementName=Divider}"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Vertical">
            <!--Showing x of y Actors-->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="Showing: " Foreground="{StaticResource col_muted_foreground}"/>
                <!--Data-->
                <TextBlock Text="{Binding Path=MatchingActors}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource col_foreground}"/>
                <TextBlock Text="of " Foreground="{StaticResource col_muted_foreground}"/>
                <!--Data-->
                <TextBlock Text="{Binding Path=TotalActors}" VerticalAlignment="Center" 
                           Foreground="{StaticResource col_foreground}"/>
                <TextBlock Text=" Actors." Foreground="{StaticResource col_muted_foreground}"/>
            </StackPanel>
            
            <ListBox 
                     ItemsSource="{Binding Actors}" 
                     Background="Transparent" 
                     BorderThickness="0" 
                     HorizontalAlignment="Stretch" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.OpenActorCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"
                        BorderThickness="0"
                        Background="Transparent">
                            <Grid Width="300" Background="{StaticResource col_card}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="{StaticResource col_muted}" Width="75" Height="75" CornerRadius="75">
                                    <TextBlock Text="{Binding Initials}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="36"
                                               FontFamily="{StaticResource font_headers}"
                                               Foreground="{StaticResource col_muted_foreground}"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="10">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontFamily="{StaticResource font_text}"
                                               Foreground="{StaticResource col_foreground}"/>
                                    <TextBlock Text="{Binding BirthYear, StringFormat=Born {0}}"
                                               FontSize="13"
                                               Foreground="{StaticResource col_muted_foreground}"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource icon_film}" Width="13" Height="13" Stretch="Uniform" Fill="{StaticResource col_accent}" Margin="5"/>
                                        <TextBlock Text="{Binding ProjectCount, StringFormat=Films: {0}}" Foreground="{StaticResource col_accent}" Margin="5"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <ItemsControl ItemsSource="{Binding SampleProjects}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#22FFFFFF"
                                                            CornerRadius="3"
                                                            Padding="4,1"
                                                            Margin="0,0,5,0">
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource col_foreground}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="6"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>
            

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Previous 50" Command="{Binding PreviousPageCommand}" Style="{StaticResource HomeDarkButtonStyle}" Cursor="Hand" Margin="5,0"/>
            <Button Content="Next 50" Command="{Binding NextPageCommand}" Style="{StaticResource HomePrimaryButtonStyle}" Cursor="Hand" Margin="5,0"/>
        </StackPanel>
    </Grid>
</UserControl>
